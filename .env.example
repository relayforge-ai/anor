# ANOR content pipeline — sovereign endpoints (Dawes now, Nauvoo later)
# Copy to .env and point at your fleet. NO secrets committed.

# OpenAI-compatible chat base (Ollama example: http://127.0.0.1:11434/v1)
LLM_URL=
LLM_MODEL=qwen2.5:32b
LLM_API_KEY=

# Image generation — ComfyUI root OR OpenAI-compatible /v1 images base
# Comfy example: http://127.0.0.1:8188
# OpenAI-style:  http://127.0.0.1:8000/v1
IMAGE_URL=
IMAGE_MODEL=v1-5-pruned-emaonly.safetensors
IMAGE_API_KEY=
IMAGE_BACKEND=auto
# When IMAGE_URL is set but Comfy/OpenAI images fail (timeout, 5xx), write a
# placeholder still so video renders can finish. Set 0 for strict remote-only.
# ANOR_IMAGE_FALLBACK_MOCK=1

# TTS — OpenAI-compatible audio/speech OR custom HTTP that returns audio bytes
# Example: http://127.0.0.1:8880/v1
TTS_URL=
TTS_MODEL=tts-1
TTS_API_KEY=
TTS_BACKEND=auto

# Force placeholders (CI / offline demos)
# ANOR_MOCK_MEDIA=1

# Keep per-segment stills/audio/clips after successful render (default: delete work/)
# ANOR_KEEP_VIDEO_WORK=1

# Optional style prefix prepended to every image prompt
# ANOR_STYLE_PREFIX=painterly historical documentary still, no text, no watermark,

# --- Webapp security (Forked History /api/fork) ---
# ANOR_FORK_RATE_LIMIT=20      # max forks per window per client
# ANOR_FORK_LLM_RATE=5        # max use_llm forks per window
# ANOR_FORK_RATE_WINDOW=60    # window seconds
# ANOR_API_RATE_LIMIT=180     # global /api/* ceiling per client (health exempt)
# ANOR_API_RATE_WINDOW=60
# ANOR_RATE_LIMIT_MAX_KEYS=10000  # max distinct client keys retained per limiter
# ANOR_TRUST_PROXY=0          # set 1 only behind a reverse proxy that sets X-Forwarded-For
# ANOR_HEALTH_DETAIL=0        # set 1 to expose full /api/health (limits, pipeline, inventory)
# ANOR_HEALTH_TOKEN=          # if set, full health requires header X-ANOR-Health-Token
# ANOR_MAX_BODY_BYTES=16384
# ANOR_MAX_SEED_CHARS=500

# --- Upstream HTTP resilience (LLM / IMAGE / TTS) ---
# ANOR_HTTP_RETRIES=3         # retries after first failure (total attempts = retries+1)
# ANOR_HTTP_RETRY_BASE=0.5    # initial backoff seconds
# ANOR_HTTP_RETRY_MAX=8.0     # backoff cap seconds
# ANOR_HTTP_RETRY_JITTER=0.25 # fractional jitter on delay
# ANOR_MAX_MEDIA_BYTES=26214400  # max bytes for secondary image downloads (default 25MiB)

# --- Async video render queue ---
# ANOR_VIDEO_MAX_CONCURRENT=1
# ANOR_VIDEO_MAX_QUEUED=8
# ANOR_VIDEO_JOB_TTL_S=3600
# ANOR_VIDEO_JOB_TIMEOUT_S=600  # wall-clock max per render (seconds)
# ANOR_MIN_FREE_DISK_MB=512   # refuse video enqueue when free space is below this (0=disable)
# ANOR_FFMPEG_CHECK_CACHE_S=30  # cache ffmpeg -version for health/stats (0=always probe)
# ANOR_CATALOG_CACHE_S=15       # cache built catalog+available flags (0=rebuild every request)
# ANOR_SCENARIOS_CACHE_S=30     # cache pack list + per-pack detail payloads (0=rebuild)
# ANOR_VIDEO_RATE_LIMIT=3     # enqueues per client per window
# ANOR_VIDEO_RATE_WINDOW=300  # seconds

# --- HTTP security headers ---
# ANOR_CORS_ORIGIN=*          # set to your site origin in production
# ANOR_CSP=                   # override full Content-Security-Policy if needed
# ANOR_HSTS_MAX_AGE=31536000  # enable HSTS on HTTPS (seconds); omit for local HTTP
# ANOR_HSTS_SUBDOMAINS=0      # set 1 to add includeSubDomains
# ANOR_HSTS_PRELOAD=0         # set 1 only if you intend to submit to HSTS preload
# ANOR_LOG_HEALTH=0           # set 1 to access-log /api/health probes (silent by default)

# --- Scholar membership (server-side gate for LLM + video jobs) ---
# When ANOR_MEMBER_SECRET is set (or ANOR_MEMBER_ENFORCE=1), expensive ops require
# header X-ANOR-Member: <token> from POST /api/member/demo (or Stripe after pay).
# ANOR_MEMBER_SECRET=
# ANOR_MEMBER_ENFORCE=0
# ANOR_MEMBER_TTL_S=86400
# ANOR_DEMO_TOKEN_RATE_LIMIT=10
# ANOR_DEMO_TOKEN_RATE_WINDOW=3600
