# ANOR content pipeline — sovereign endpoints (Dawes now, Nauvoo later)
# Copy to .env and point at your fleet. NO secrets committed.

# OpenAI-compatible chat base (Ollama example: http://127.0.0.1:11434/v1)
LLM_URL=
LLM_MODEL=qwen2.5:32b
LLM_API_KEY=

# Image generation — ComfyUI root OR OpenAI-compatible /v1 images base
# Comfy example: http://127.0.0.1:8188
# OpenAI-style:  http://127.0.0.1:8000/v1
IMAGE_URL=
IMAGE_MODEL=v1-5-pruned-emaonly.safetensors
IMAGE_API_KEY=
IMAGE_BACKEND=auto

# TTS — OpenAI-compatible audio/speech OR custom HTTP that returns audio bytes
# Example: http://127.0.0.1:8880/v1
TTS_URL=
TTS_MODEL=tts-1
TTS_API_KEY=
TTS_BACKEND=auto

# Force placeholders (CI / offline demos)
# ANOR_MOCK_MEDIA=1

# Optional style prefix prepended to every image prompt
# ANOR_STYLE_PREFIX=painterly historical documentary still, no text, no watermark,
